{
  "name": "dbunny",
  "displayName": "DBunny",
  "description": "Hop into your databases! Fast and friendly database management for VS Code",
  "version": "2.5.0",
  "publisher": "chimaek",
  "author": "chimaek",
  "license": "MIT",
  "icon": "resources/bunny-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/chimaek/dbunny"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Data Science",
    "Testing",
    "Other"
  ],
  "keywords": [
    "database",
    "mysql",
    "postgresql",
    "sqlite",
    "h2",
    "mongodb",
    "redis",
    "sql",
    "db",
    "bunny",
    "dbunny"
  ],
  "activationEvents": [
    "onView:dbunny.explorer",
    "onCommand:dbunny.addConnection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbunny",
          "title": "DBunny",
          "icon": "resources/bunny.svg"
        }
      ]
    },
    "views": {
      "dbunny": [
        {
          "id": "dbunny.explorer",
          "name": "Connections"
        },
        {
          "id": "dbunny.savedQueries",
          "name": "Saved Queries"
        },
        {
          "id": "dbunny.queries",
          "name": "Query History"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dbunny.explorer",
        "contents": "No database connections yet.\n[Add Connection](command:dbunny.addConnection)"
      },
      {
        "view": "dbunny.savedQueries",
        "contents": "No saved queries yet.\nOpen a SQL file and use Ctrl+Shift+S (Cmd+Shift+S on Mac) to save a query."
      },
      {
        "view": "dbunny.queries",
        "contents": "No query history yet.\nExecute a query with Ctrl+Enter (or Cmd+Enter on Mac) to see it here."
      }
    ],
    "commands": [
      {
        "command": "dbunny.addConnection",
        "title": "Add Connection",
        "category": "DBunny",
        "icon": "$(add)"
      },
      {
        "command": "dbunny.editConnection",
        "title": "Edit Connection",
        "category": "DBunny",
        "icon": "$(edit)"
      },
      {
        "command": "dbunny.deleteConnection",
        "title": "Delete Connection",
        "category": "DBunny",
        "icon": "$(trash)"
      },
      {
        "command": "dbunny.toggleReadOnly",
        "title": "Toggle Read-Only Mode",
        "category": "DBunny",
        "icon": "$(lock)"
      },
      {
        "command": "dbunny.connect",
        "title": "Connect",
        "category": "DBunny",
        "icon": "$(plug)"
      },
      {
        "command": "dbunny.disconnect",
        "title": "Disconnect",
        "category": "DBunny",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "dbunny.executeQuery",
        "title": "Execute Query",
        "category": "DBunny",
        "icon": "$(play)"
      },
      {
        "command": "dbunny.refreshConnection",
        "title": "Refresh",
        "category": "DBunny",
        "icon": "$(refresh)"
      },
      {
        "command": "dbunny.exportData",
        "title": "Export Data",
        "category": "DBunny",
        "icon": "$(export)"
      },
      {
        "command": "dbunny.newQuery",
        "title": "New Query",
        "category": "DBunny",
        "icon": "$(new-file)"
      },
      {
        "command": "dbunny.editTableData",
        "title": "Edit Table Data",
        "category": "DBunny",
        "icon": "$(table)"
      },
      {
        "command": "dbunny.clearHistory",
        "title": "Clear History",
        "category": "DBunny",
        "icon": "$(trash)"
      },
      {
        "command": "dbunny.copyQuery",
        "title": "Copy Query",
        "category": "DBunny",
        "icon": "$(copy)"
      },
      {
        "command": "dbunny.viewKeyData",
        "title": "View Data",
        "category": "DBunny",
        "icon": "$(eye)"
      },
      {
        "command": "dbunny.executeQueryAtCursor",
        "title": "Run Query",
        "category": "DBunny",
        "icon": "$(play)"
      },
      {
        "command": "dbunny.saveQueryBookmark",
        "title": "Save Query",
        "category": "DBunny",
        "icon": "$(bookmark)"
      },
      {
        "command": "dbunny.loadSavedQuery",
        "title": "Load Saved Query",
        "category": "DBunny",
        "icon": "$(go-to-file)"
      },
      {
        "command": "dbunny.editSavedQuery",
        "title": "Edit Saved Query",
        "category": "DBunny",
        "icon": "$(edit)"
      },
      {
        "command": "dbunny.deleteSavedQuery",
        "title": "Delete Saved Query",
        "category": "DBunny",
        "icon": "$(trash)"
      },
      {
        "command": "dbunny.clearSavedQueries",
        "title": "Clear All Saved Queries",
        "category": "DBunny",
        "icon": "$(trash)"
      },
      {
        "command": "dbunny.formatSQL",
        "title": "Format SQL",
        "category": "DBunny",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "dbunny.copyTableSchema",
        "title": "Copy CREATE TABLE",
        "category": "DBunny",
        "icon": "$(copy)"
      },
      {
        "command": "dbunny.explainQuery",
        "title": "Explain Query",
        "category": "DBunny",
        "icon": "$(debug-alt)"
      },
      {
        "command": "dbunny.setConnectionGroup",
        "title": "Move to Group",
        "category": "DBunny",
        "icon": "$(folder)"
      },
      {
        "command": "dbunny.renameGroup",
        "title": "Rename Group",
        "category": "DBunny",
        "icon": "$(edit)"
      },
      {
        "command": "dbunny.deleteGroup",
        "title": "Delete Group",
        "category": "DBunny",
        "icon": "$(trash)"
      },
      {
        "command": "dbunny.showERD",
        "title": "Show ERD Diagram",
        "category": "DBunny",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "dbunny.compareSchema",
        "title": "Compare Schema",
        "category": "DBunny",
        "icon": "$(diff)"
      },
      {
        "command": "dbunny.generateMockData",
        "title": "Generate Mock Data",
        "category": "DBunny",
        "icon": "$(beaker)"
      },
      {
        "command": "dbunny.showMigration",
        "title": "DB Migration",
        "category": "DBunny",
        "icon": "$(versions)"
      },
      {
        "command": "dbunny.showMonitoring",
        "title": "Real-time Monitoring",
        "category": "DBunny",
        "icon": "$(pulse)"
      },
      {
        "command": "dbunny.openQueryTabs",
        "title": "Open Query Editor (Multi-Tab)",
        "category": "DBunny",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "dbunny.toggleFavorite",
        "title": "Toggle Favorite",
        "category": "DBunny",
        "icon": "$(star)"
      },
      {
        "command": "dbunny.duplicateConnection",
        "title": "Duplicate Connection",
        "category": "DBunny",
        "icon": "$(copy)"
      },
      {
        "command": "dbunny.exportConnection",
        "title": "Export Connection",
        "category": "DBunny",
        "icon": "$(export)"
      },
      {
        "command": "dbunny.exportAllConnections",
        "title": "Export All Connections",
        "category": "DBunny",
        "icon": "$(export)"
      },
      {
        "command": "dbunny.importConnections",
        "title": "Import Connections",
        "category": "DBunny",
        "icon": "$(import)"
      },
      {
        "command": "dbunny.saveAsTemplate",
        "title": "Save as Template",
        "category": "DBunny",
        "icon": "$(bookmark)"
      },
      {
        "command": "dbunny.newFromTemplate",
        "title": "New from Template",
        "category": "DBunny",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "dbunny.deleteTemplate",
        "title": "Delete Template",
        "category": "DBunny",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbunny.addConnection",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        },
        {
          "command": "dbunny.refreshConnection",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        },
        {
          "command": "dbunny.openQueryTabs",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        },
        {
          "command": "dbunny.saveQueryBookmark",
          "when": "view == dbunny.savedQueries",
          "group": "navigation"
        },
        {
          "command": "dbunny.clearSavedQueries",
          "when": "view == dbunny.savedQueries",
          "group": "navigation"
        },
        {
          "command": "dbunny.clearHistory",
          "when": "view == dbunny.queries",
          "group": "navigation"
        },
        {
          "command": "dbunny.importConnections",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        },
        {
          "command": "dbunny.newFromTemplate",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        },
        {
          "command": "dbunny.exportAllConnections",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "dbunny.connect",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "inline@1"
        },
        {
          "command": "dbunny.editConnection",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "inline@2"
        },
        {
          "command": "dbunny.deleteConnection",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "inline@3"
        },
        {
          "command": "dbunny.toggleReadOnly",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "inline@4"
        },
        {
          "command": "dbunny.setConnectionGroup",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "navigation@1"
        },
        {
          "command": "dbunny.duplicateConnection",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "navigation@2"
        },
        {
          "command": "dbunny.exportConnection",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "navigation@3"
        },
        {
          "command": "dbunny.saveAsTemplate",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "navigation@4"
        },
        {
          "command": "dbunny.renameGroup",
          "when": "view == dbunny.explorer && viewItem == group",
          "group": "inline@1"
        },
        {
          "command": "dbunny.deleteGroup",
          "when": "view == dbunny.explorer && viewItem == group",
          "group": "inline@2"
        },
        {
          "command": "dbunny.newQuery",
          "when": "view == dbunny.explorer && viewItem == database",
          "group": "inline@1"
        },
        {
          "command": "dbunny.showERD",
          "when": "view == dbunny.explorer && viewItem == database",
          "group": "inline@2"
        },
        {
          "command": "dbunny.showMigration",
          "when": "view == dbunny.explorer && viewItem == database",
          "group": "navigation@1"
        },
        {
          "command": "dbunny.showMonitoring",
          "when": "view == dbunny.explorer && viewItem == database",
          "group": "navigation@2"
        },
        {
          "command": "dbunny.editTableData",
          "when": "view == dbunny.explorer && viewItem == table-sql",
          "group": "inline@1"
        },
        {
          "command": "dbunny.copyTableSchema",
          "when": "view == dbunny.explorer && viewItem == table-sql",
          "group": "inline@2"
        },
        {
          "command": "dbunny.compareSchema",
          "when": "view == dbunny.explorer && viewItem == table-sql",
          "group": "navigation@1"
        },
        {
          "command": "dbunny.generateMockData",
          "when": "view == dbunny.explorer && viewItem == table-sql",
          "group": "navigation@2"
        },
        {
          "command": "dbunny.toggleFavorite",
          "when": "view == dbunny.explorer && viewItem == table-sql",
          "group": "inline@3"
        },
        {
          "command": "dbunny.editTableData",
          "when": "view == dbunny.explorer && viewItem == table-sql-favorite",
          "group": "inline@1"
        },
        {
          "command": "dbunny.copyTableSchema",
          "when": "view == dbunny.explorer && viewItem == table-sql-favorite",
          "group": "inline@2"
        },
        {
          "command": "dbunny.toggleFavorite",
          "when": "view == dbunny.explorer && viewItem == table-sql-favorite",
          "group": "inline@3"
        },
        {
          "command": "dbunny.compareSchema",
          "when": "view == dbunny.explorer && viewItem == table-sql-favorite",
          "group": "navigation@1"
        },
        {
          "command": "dbunny.generateMockData",
          "when": "view == dbunny.explorer && viewItem == table-sql-favorite",
          "group": "navigation@2"
        },
        {
          "command": "dbunny.viewKeyData",
          "when": "view == dbunny.explorer && viewItem == table-nosql",
          "group": "inline"
        },
        {
          "command": "dbunny.editSavedQuery",
          "when": "view == dbunny.savedQueries && viewItem == savedQuery",
          "group": "inline@1"
        },
        {
          "command": "dbunny.deleteSavedQuery",
          "when": "view == dbunny.savedQueries && viewItem == savedQuery",
          "group": "inline@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "dbunny.executeQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorLangId == sql || editorLangId == plpgsql || editorLangId == mysql"
      },
      {
        "command": "dbunny.executeQuery",
        "key": "f5",
        "when": "editorLangId == sql || editorLangId == plpgsql || editorLangId == mysql"
      },
      {
        "command": "dbunny.newQuery",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      },
      {
        "command": "dbunny.addConnection",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d"
      },
      {
        "command": "dbunny.saveQueryBookmark",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorLangId == sql || editorLangId == plpgsql || editorLangId == mysql"
      },
      {
        "command": "dbunny.formatSQL",
        "key": "shift+alt+f",
        "mac": "shift+alt+f",
        "when": "editorLangId == sql || editorLangId == plpgsql || editorLangId == mysql"
      },
      {
        "command": "dbunny.explainQuery",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorLangId == sql || editorLangId == plpgsql || editorLangId == mysql"
      },
      {
        "command": "dbunny.openQueryTabs",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ],
    "configuration": {
      "title": "DBunny",
      "properties": {
        "dbunny.connections": {
          "type": "array",
          "default": [],
          "description": "Saved database connections"
        },
        "dbunny.queryTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Query timeout in milliseconds"
        },
        "dbunny.maxResults": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of result rows"
        },
        "dbunny.language": {
          "type": "string",
          "enum": [
            "ko",
            "en",
            "auto"
          ],
          "default": "auto",
          "description": "Interface language (auto: follow VS Code language)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test",
    "package-extension": "vsce package",
    "publish-extension": "vsce publish"
  },
  "dependencies": {
    "mongodb": "^6.10.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "sql-formatter": "^15.4.0",
    "sql.js": "^1.13.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.16.0",
    "@types/sql.js": "^1.4.9",
    "@types/ssh2": "^1.15.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.0.0",
    "glob": "^13.0.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.51.0"
  }
}
