{
  "name": "dbunny",
  "displayName": "DBunny",
  "description": "Hop into your databases! Fast and friendly database management for VS Code",
  "version": "1.0.0",
  "publisher": "your-publisher-name",
  "author": "Your Name",
  "license": "MIT",
  "icon": "resources/bunny-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/dbunny"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "keywords": [
    "database",
    "mysql",
    "postgresql",
    "sqlite",
    "mongodb",
    "redis",
    "sql",
    "db",
    "bunny",
    "dbunny"
  ],
  "activationEvents": [
    "onView:dbunny.explorer",
    "onCommand:dbunny.addConnection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbunny",
          "title": "DBunny",
          "icon": "resources/bunny.svg"
        }
      ]
    },
    "views": {
      "dbunny": [
        {
          "id": "dbunny.explorer",
          "name": "Connections"
        },
        {
          "id": "dbunny.queries",
          "name": "Query History"
        }
      ]
    },
    "commands": [
      {
        "command": "dbunny.addConnection",
        "title": "Add Connection",
        "category": "DBunny",
        "icon": "$(add)"
      },
      {
        "command": "dbunny.editConnection",
        "title": "Edit Connection",
        "category": "DBunny",
        "icon": "$(edit)"
      },
      {
        "command": "dbunny.deleteConnection",
        "title": "Delete Connection",
        "category": "DBunny",
        "icon": "$(trash)"
      },
      {
        "command": "dbunny.connect",
        "title": "Connect",
        "category": "DBunny",
        "icon": "$(plug)"
      },
      {
        "command": "dbunny.disconnect",
        "title": "Disconnect",
        "category": "DBunny",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "dbunny.executeQuery",
        "title": "Execute Query",
        "category": "DBunny",
        "icon": "$(play)"
      },
      {
        "command": "dbunny.refreshConnection",
        "title": "Refresh",
        "category": "DBunny",
        "icon": "$(refresh)"
      },
      {
        "command": "dbunny.exportData",
        "title": "Export Data",
        "category": "DBunny",
        "icon": "$(export)"
      },
      {
        "command": "dbunny.newQuery",
        "title": "New Query",
        "category": "DBunny",
        "icon": "$(new-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbunny.addConnection",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        },
        {
          "command": "dbunny.refreshConnection",
          "when": "view == dbunny.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "dbunny.connect",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "inline@1"
        },
        {
          "command": "dbunny.editConnection",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "inline@2"
        },
        {
          "command": "dbunny.deleteConnection",
          "when": "view == dbunny.explorer && viewItem == connection",
          "group": "inline@3"
        },
        {
          "command": "dbunny.newQuery",
          "when": "view == dbunny.explorer && viewItem == database",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "DBunny",
      "properties": {
        "dbunny.connections": {
          "type": "array",
          "default": [],
          "description": "Saved database connections"
        },
        "dbunny.queryTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Query timeout in milliseconds"
        },
        "dbunny.maxResults": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of result rows"
        },
        "dbunny.language": {
          "type": "string",
          "enum": [
            "ko",
            "en",
            "auto"
          ],
          "default": "auto",
          "description": "Interface language (auto: follow VS Code language)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test",
    "package-extension": "vsce package",
    "publish-extension": "vsce publish"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "mongodb": "^6.10.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.16.0",
    "@types/ssh2": "^1.15.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.0.0",
    "glob": "^13.0.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.51.0"
  }
}
